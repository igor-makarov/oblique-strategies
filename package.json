{
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#app/*": "./app/*",
    "#types/*": "./.react-router/types/*"
  },
  "scripts": {
    "dev": "react-router dev --host 0.0.0.0 --port 3000",
    "build": "react-router build",
    "postbuild": "node scripts/generate-cloudflare-pages-artifacts.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "npm run build && wrangler dev",
    "typecheck": "react-router typegen && tsc --noEmit",
    "check": "react-router typegen && tsc --noEmit",
    "format": "prettier --write --list-different .",
    "format:check": "prettier --check .",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@forge42/seo-tools": "^1.4.5",
    "@react-router/dev": "^7.10.1",
    "@react-router/node": "^7.10.1",
    "@react-router/serve": "^7.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.10.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@fontsource/inter": "^5.2.8",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/vite-react": "^7.0.2",
    "@types/node": "^25.5.0",
    "isbot": "^5.1.36",
    "prettier": "^3.6.2",
    "satori": "^0.26.0",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.78.0"
  }
}
