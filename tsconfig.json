{
  "extends": "@tsconfig/vite-react/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#src/*": ["src/*"],
      "#app/*": ["app/*"],
      "#types/*": [".react-router/types/*"]
    },
    "types": ["vite/client"],
    "rootDirs": [".", ".react-router/types"]
  },
  "include": [".react-router/types/**/*", "worker-configuration.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["dist", "build", "coverage", "node_modules"]
}
